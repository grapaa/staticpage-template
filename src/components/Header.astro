---
import { site } from '../lib/site.config';
import { url } from '../lib/url';

const currentPath = Astro.url.pathname;
---

<header class="bg-background/90 backdrop-blur-md border-b border-border sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo: replace text with <img> if you have a logo asset -->
    <a href={url('/')} class="font-display text-xl font-semibold text-primary hover:text-primary-light transition-colors">
      {site.name}
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-1">
      {site.nav.map((item) => (
        <li>
          <a
            href={url(item.href)}
            class:list={[
              'px-4 py-2 text-sm font-medium rounded-md transition-colors',
              currentPath === url(item.href) || currentPath === url(item.href) + '/'
                ? 'text-primary'
                : 'text-muted hover:text-text',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="ml-4">
        <a
          href={url(site.cta.href)}
          class="inline-flex items-center px-5 py-2 text-sm font-medium text-white bg-primary rounded-full hover:bg-primary-light transition-all duration-200"
        >
          {site.cta.label}
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-muted hover:text-primary transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border bg-surface/95 backdrop-blur-md">
    <ul class="px-4 py-4 space-y-1">
      {site.nav.map((item) => (
        <li>
          <a
            href={url(item.href)}
            class:list={[
              'block px-4 py-2.5 text-sm font-medium rounded-lg transition-colors',
              currentPath === url(item.href) || currentPath === url(item.href) + '/'
                ? 'text-primary bg-primary/5'
                : 'text-muted hover:text-text hover:bg-black/5',
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href={url(site.cta.href)}
          class="flex items-center justify-center px-4 py-2.5 text-sm font-medium text-white bg-primary rounded-lg hover:bg-primary-light transition-colors"
        >
          {site.cta.label}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
