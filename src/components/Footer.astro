---
import { site } from '../lib/site.config';
import { url } from '../lib/url';

const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-dark">
  <div class="h-px bg-accent/30"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-12 pb-12 border-b border-white/10">
      <!-- Brand -->
      <div>
        <span class="font-display text-3xl font-semibold text-white">{site.name}</span>
        <p class="mt-3 text-white/40 text-sm max-w-xs leading-relaxed">{site.tagline}</p>
      </div>

      <!-- Links -->
      <nav class="grid grid-cols-2 gap-x-12 gap-y-2.5">
        {site.nav.map((item) => (
          <a href={url(item.href)} class="text-sm text-white/45 hover:text-white transition-colors">
            {item.label}
          </a>
        ))}
        <a href={`mailto:${site.email}`} class="text-sm text-white/45 hover:text-white transition-colors">
          {site.email}
        </a>
        <span class="text-sm text-white/25">{site.location}</span>
      </nav>
    </div>

    <div class="pt-8">
      <p class="text-xs text-white/25">&copy; {currentYear} {site.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
